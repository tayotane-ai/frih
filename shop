          <div class="field-row">
            <div class="field"><label>First Name</label><input type="text" id="fname" placeholder="Tayo"></div>
            <div class="field"><label>Last Name</label><input type="text" id="lname" placeholder="Tane"></div>
          </div>
          <div class="field"><label>Email</label><input type="email" id="email" placeholder="you@example.com"></div>
          <div class="field"><label>Phone</label><input type="tel" id="phone" placeholder="+234 800 000 0000"></div>
          <div class="field"><label>Delivery Address</label><input type="text" id="address" placeholder="123 Your Street, Lagos"></div>
