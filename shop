<script>

const IC={
  cart:'<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>',
  plus:'<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>',
  minus:'<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12"/></svg>',
  trash:'<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>',
  arrow:'<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>',
  lock:'<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>',
  tag:'<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>',
  check:'<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>',
  x:'<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>',
  back:'<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>',
  clock:'<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>',
  scissors:'<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><line x1="20" y1="4" x2="8.12" y2="15.88"/><line x1="14.47" y1="14.48" x2="20" y2="20"/><line x1="8.12" y1="8.12" x2="12" y2="12"/></svg>',
  search:'<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>',
  truck:'<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>',
  home:'<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>',
  ig:'<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>',
};
const IMAGES = {
  "Black_Boogie3erfdas.png":"data:image/webp;base64,",
  "Blue_Boogie3erfdas.png":"data:image/webp;base64,",
  "Brown_Boogie3erfdas.png":"data:image/webp;base64,",
  "Green_Boogie3erfdas.png":"data:image/webp;base64,",
  "Pink_Boogie3erfdas.png":"data:image/webp;base64,",
  "Red_Boogie3erfdas.png":"data:image/webp;base64,",
  "Red_Boogie-3.png":"data:image/webp;base64,",
  "Red_Boogie-2.png":"data:image/webp;base64,",
  "Red_Boogie-1.png":"data:image/webp;base64,",
  "Red_Boogie.png":"data:image/webp;base64,",
  "Red_Boogie-4.png":"data:image/webp;base64,",
};



/* ============================================================
   PAYSTACK CONFIG — Replace with your real keys from paystack.com
   1. Sign up at paystack.com (individual account, BVN only, no CAC)
   2. Get your PUBLIC key from Settings > API Keys & Webhooks
   3. Replace the key below
   ============================================================ */
const PAYSTACK_PUBLIC_KEY = "pk_test_5eda1a14a812e2709f452e70d492af468c11ce2e";
// ↑ TEMPORARILY back to TEST key — verify the popup opens correctly on the live
//   site first using a Paystack test card, then swap back to the live key:
//   pk_live_a9d2c78519d1b31b31e3c88d64d628ccdc1b0454

const PANTS=[
  {name:"Cobalt",cat:["palazzo"],file:"Blue_Boogie3erfdas.png",desc:"High-rise palazzo in a clean cobalt drape.",tags:["Wide-leg","Pleated"]},
  {name:"Crimson",cat:["palazzo"],file:"Red_Boogie3erfdas.png",desc:"Vivid crimson wide-leg. Tailored waist, fluid fall.",tags:["Wide-leg","Tailored"]},
  {name:"Forest",cat:["palazzo"],file:"Green_Boogie3erfdas.png",desc:"Deep forest palazzo with architectural sweep.",tags:["Wide-leg","Pleated"]},
  {name:"Rose",cat:["palazzo"],file:"Pink_Boogie3erfdas.png",desc:"Soft rose palazzo. Full leg, pressed seams.",tags:["Wide-leg","Soft"]},
  {name:"Rust",cat:["palazzo"],file:"Brown_Boogie3erfdas.png",desc:"Warm rust wide-leg for cooler light.",tags:["Wide-leg","Heavy drape"]},
  {name:"Ink",cat:["palazzo"],file:"Black_Boogie3erfdas.png",desc:"The all-day black palazzo. Total ease.",tags:["Wide-leg","Everyday"]},
  {name:"Sky",cat:["jorts","new"],file:"Red_Boogie-3.png",desc:"Sky-blue jort, knee-length wide leg.",tags:["Cropped","Pleated"]},
  {name:"Blush",cat:["jorts","new"],file:"Red_Boogie-2.png",desc:"Blush jort. Same width, summer-weight.",tags:["Cropped","Summer"]},
  {name:"Bone",cat:["jorts","new"],file:"Red_Boogie-1.png",desc:"Bone jort, buttoned waist, deep pleat.",tags:["Cropped","Neutral"]},
  {name:"Maize",cat:["jorts","new"],file:"Red_Boogie.png",desc:"Maize jort, pressed and pleated.",tags:["Cropped","Pleated"]},
  {name:"Scarlet",cat:["jorts","new"],file:"Red_Boogie-4.png",desc:"Scarlet jort in vivid red. Knee-length, deep pleat.",tags:["Cropped","Bold"]},
];
const PRICE=25000,OLD=35000,DISC=Math.round((1-PRICE/OLD)*100);
let cart={};
function cartQty(i){return cart[i]||0}
function totalItems(){return Object.values(cart).reduce((a,b)=>a+b,0)}
function totalPrice(){return totalItems()*PRICE}

// Static icon injections
document.getElementById("igLink").innerHTML=IC.ig;
document.getElementById("cartIconWrap").insertAdjacentHTML("afterbegin",IC.cart);
document.getElementById("discountPill").innerHTML=IC.tag+" 29% OFF \u2014 Preorder";
document.getElementById("closeModal").innerHTML=IC.x;
document.getElementById("toPayment").innerHTML=IC.lock+" Pay with Paystack";
document.getElementById("psNote").innerHTML=IC.lock+`<span>Secure payment powered by <b>Paystack</b>. Cards, bank transfer & USSD accepted. Preorder discount: <b>${DISC}% off</b>.</span>`;
document.getElementById("opCheck").innerHTML=IC.check;
document.getElementById("tlHead").innerHTML=IC.clock+" Production Timeline";
document.getElementById("shopAgain").innerHTML=IC.back+" Continue Shopping";
document.getElementById("shopAgain").onclick=()=>location.reload();
document.getElementById("timeline").innerHTML=`
  <div class="tl-step done"><div class="tl-dot"></div><div class="tl-title">${IC.check} Order Placed</div><div class="tl-desc">Just now \u2014 confirmed</div></div>
  <div class="tl-step current"><div class="tl-dot"></div><div class="tl-title">${IC.scissors} In Production</div><div class="tl-desc">Starts within 48 hours \u00b7 2\u20133 weeks</div></div>
  <div class="tl-step"><div class="tl-dot"></div><div class="tl-title">${IC.search} Quality Check</div><div class="tl-desc">1\u20132 days after production</div></div>
  <div class="tl-step"><div class="tl-dot"></div><div class="tl-title">${IC.truck} Shipped</div><div class="tl-desc">3\u20135 business days delivery</div></div>
  <div class="tl-step"><div class="tl-dot"></div><div class="tl-title">${IC.home} Delivered</div><div class="tl-desc">Estimated 4\u20135 weeks total</div></div>`;

// TABS
const TABS=[["all","All"],["palazzo","Palazzo"],["jorts","Jorts"],["new","New In"]];
const count=c=>c==="all"?PANTS.length:PANTS.filter(p=>p.cat.includes(c)).length;
document.getElementById("tabs").innerHTML=TABS.map(([c,l],i)=>`<button class="tab" role="tab" aria-selected="${i===0}" data-cat="${c}">${l}<span class="n">${String(count(c)).padStart(2,"0")}</span></button>`).join("");

// CARDS — no floating info, bigger product, white bg
const grid=document.getElementById("grid");
const isMobile=window.matchMedia("(max-width:900px)").matches||"ontouchstart"in window;
function renderCards(){
  grid.innerHTML=PANTS.map((p,i)=>{
    const kind=p.cat.includes("jorts")?"Jort":"Palazzo",src=IMAGES[p.file],q=cartQty(i),inCart=q>0;
    const mob=isMobile?" always":"";
    const img=src?`<div class="photo"><img src="${src}" alt="${p.name}" loading="lazy"></div>`:"";
    const leftBtn=q<=1?`<button class="qbtn del" data-action="delete" data-idx="${i}">${IC.trash}</button>`:`<button class="qbtn" data-action="minus" data-idx="${i}">${IC.minus}</button>`;
    return `<article class="card in" data-cat="${p.cat.join(' ')}" data-idx="${i}">
      ${img}
      <div class="tag-idx">${String(i+1).padStart(2,"0")} / ${String(PANTS.length).padStart(2,"0")}</div>
      <div class="label">
        <div class="lab-default" style="${inCart?'pointer-events:none':''}"><span>${p.name} ${kind}</span><div class="pricing"><span class="now">\u20a625,000</span><span class="was">\u20a635,000</span></div></div>
        <button class="lab-atc ${inCart?'':'can-add'}${mob}" data-idx="${i}">${IC.plus} Add to Cart</button>
        <div class="lab-qty ${inCart?'has-items':''}${mob}" data-idx="${i}">
          ${leftBtn}
          <div class="qcount">${q}</div>
          <button class="qbtn" data-action="plus" data-idx="${i}">${IC.plus}</button>
        </div>
      </div>
    </article>`;
  }).join("");
  reApplyFilter();
}
function reApplyFilter(){const at=document.querySelector('.tab[aria-selected="true"]');if(at){const cat=at.dataset.cat;document.querySelectorAll(".card").forEach(c=>{c.classList.toggle("hide",cat!=="all"&&!c.dataset.cat.split(" ").includes(cat))})}}
renderCards();
const io=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting){e.target.classList.add("in");io.unobserve(e.target)}}),{threshold:.08});
document.querySelectorAll(".card").forEach(c=>io.observe(c));
document.getElementById("tabs").addEventListener("click",e=>{const t=e.target.closest(".tab");if(!t)return;[...document.getElementById("tabs").children].forEach(b=>b.setAttribute("aria-selected",b===t?"true":"false"));reApplyFilter()});

// CART ACTIONS
document.addEventListener("click",e=>{
  const atc=e.target.closest(".lab-atc");
  if(atc&&atc.classList.contains("can-add")){cart[+atc.dataset.idx]=1;updateAll();return}
  const qb=e.target.closest(".qbtn");
  if(qb){const idx=+qb.dataset.idx,a=qb.dataset.action;if(a==="plus")cart[idx]=(cart[idx]||0)+1;else if(a==="minus")cart[idx]=Math.max(1,cart[idx]-1);else if(a==="delete")delete cart[idx];updateAll();return}
});
function updateAll(){
  const n=totalItems(),t=totalPrice();
  document.getElementById("cartBadge").textContent=n;
  document.getElementById("cartCount").textContent=n;
  document.getElementById("cartItemsLabel").textContent=n===1?"item":"items";
  document.getElementById("preorderBtn").innerHTML=IC.lock+` Preorder \u00b7 \u20a6${t.toLocaleString()}`;
  document.getElementById("cartBar").classList.toggle("show",n>0);
  renderCards();
}

// MODAL
const overlay=document.getElementById("overlay");
document.getElementById("preorderBtn").addEventListener("click",openModal);
document.getElementById("closeModal").addEventListener("click",()=>overlay.classList.remove("open"));
overlay.addEventListener("click",e=>{if(e.target===overlay)overlay.classList.remove("open")});
function showMStep(n){document.querySelectorAll(".mstep").forEach(s=>s.classList.remove("active"));document.getElementById("mstep"+n).classList.add("active")}

function openModal(){showMStep(1);document.getElementById("modalTitle").textContent="Your Cart";renderModalCart();renderSummary("cartSummary");overlay.classList.add("open")}

function renderModalCart(){
  document.getElementById("cartItems").innerHTML=Object.entries(cart).map(([idx,qty])=>{
    const p=PANTS[idx],kind=p.cat.includes("jorts")?"Jort":"Palazzo",src=IMAGES[p.file];
    const lb=qty<=1?`<button class="del" data-mc="delete" data-mi="${idx}">${IC.trash}</button>`:`<button data-mc="minus" data-mi="${idx}">${IC.minus}</button>`;
    return `<div class="cart-item"><img src="${src}" alt="${p.name}"><div class="ci-info"><div class="ci-name">${p.name} ${kind}</div><div class="ci-type">${p.tags.join(" \u00b7 ")}</div></div><div class="ci-right"><div class="ci-qty">${lb}<div class="ciq">${qty}</div><button data-mc="plus" data-mi="${idx}">${IC.plus}</button></div><div class="ci-price">\u20a6${(qty*PRICE).toLocaleString()}</div></div></div>`;
  }).join("");
}
document.addEventListener("click",e=>{const btn=e.target.closest("[data-mc]");if(!btn)return;const idx=btn.dataset.mi,a=btn.dataset.mc;if(a==="plus")cart[idx]=(cart[idx]||0)+1;else if(a==="minus")cart[idx]=Math.max(1,cart[idx]-1);else if(a==="delete")delete cart[idx];updateAll();if(totalItems()===0){overlay.classList.remove("open");return}renderModalCart();renderSummary("cartSummary")});
function renderSummary(id){const n=totalItems(),sub=n*OLD,disc=n*(OLD-PRICE),total=n*PRICE;document.getElementById(id).innerHTML=`<div class="cs-row"><span>Subtotal (${n} ${n===1?"item":"items"})</span><span>\u20a6${sub.toLocaleString()}</span></div><div class="cs-row"><span>Preorder Discount (${DISC}%)</span><span class="saved">-\u20a6${disc.toLocaleString()}</span></div><div class="cs-row total"><span>Total</span><span>\u20a6${total.toLocaleString()}</span></div>`}

// PAYSTACK PAYMENT
document.getElementById("toPayment").addEventListener("click",()=>{
  const email=document.getElementById("email").value.trim();
  const fname=document.getElementById("fname").value.trim();
  if(!fname||!email){alert("Please fill in at least your name and email.");return}

  const amount=totalPrice()*100;
  const ref="FRH-"+Date.now();

  function runBuiltInCheckout(){
    document.getElementById("modalTitle").textContent="Processing Payment";
    showMStep(2);
    overlay.classList.add("open");
    setTimeout(()=>{overlay.classList.remove("open");showOrderPage(ref)},2600);
  }

  function tryPaystack(){
    overlay.classList.remove("open");
    var openedAt=Date.now();
    try{
      var handler=PaystackPop.setup({
        key:PAYSTACK_PUBLIC_KEY,
        email:email,
        amount:amount,
        ref:ref,
        callback:function(response){showOrderPage(ref)},
        onClose:function(){
          var elapsed=Date.now()-openedAt;
          // If closed within 3 seconds, Paystack rejected it — use built-in
          if(elapsed<3000){
            console.warn("[Paystack] popup closed after only "+elapsed+"ms — Paystack likely rejected the transaction (often means the account isn't approved for live charges yet, or the key/domain isn't authorized). Falling back to simulated checkout.");
            runBuiltInCheckout();
          } else {
            // User manually closed after seeing it — go back to cart
            overlay.classList.add("open");showMStep(1);
            document.getElementById("modalTitle").textContent="Your Cart";
          }
        }
      });
      handler.openIframe();
    }catch(err){
      console.error("[Paystack] setup/openIframe threw an exception — falling back to simulated checkout. Error:",err);
      runBuiltInCheckout();
    }
  }

  function loadPaystackScript(isRetry){
    var s=document.createElement("script");
    s.src="https://js.paystack.co/v1/inline.js";
    s.onload=function(){console.log("[Paystack] inline.js loaded"+(isRetry?" on retry":"")+".");tryPaystack()};
    s.onerror=function(){
      if(!isRetry){
        console.warn("[Paystack] inline.js failed to load on first attempt — retrying once in 1.2s...");
        setTimeout(function(){loadPaystackScript(true)},1200);
      } else {
        console.error("[Paystack] inline.js failed to load on retry too — this is a real network issue reaching js.paystack.co (not a Paystack account problem). Check the Network tab for the exact status of that request, and try a different network/device to rule out a local block. Falling back to simulated checkout.");
        runBuiltInCheckout();
      }
    };
    document.head.appendChild(s);
  }

  if(typeof PaystackPop!=="undefined"){
    tryPaystack();
  } else {
    loadPaystackScript(false);
  }
});

function showOrderPage(ref){
  document.getElementById("mainWrap").classList.add("hidden");
  document.getElementById("orderPage").classList.add("show");
  window.scrollTo(0,0);
  document.getElementById("orderId").textContent=ref.slice(4,16);
  document.getElementById("orderItems").innerHTML=Object.entries(cart).map(([idx,qty])=>{
    const p=PANTS[idx],kind=p.cat.includes("jorts")?"Jort":"Palazzo",src=IMAGES[p.file];
    return `<div class="cart-item"><img src="${src}" alt="${p.name}"><div class="ci-info"><div class="ci-name">${p.name} ${kind}</div><div class="ci-type">${qty}x \u00b7 ${p.tags.join(" \u00b7 ")}</div></div><div class="ci-price">\u20a6${(qty*PRICE).toLocaleString()}</div></div>`;
  }).join("");
  renderSummary("orderSummary");
  if(typeof confetti==="function"){confetti({particleCount:120,spread:80,origin:{y:.6}});setTimeout(()=>confetti({particleCount:60,spread:100,origin:{y:.5}}),400);setTimeout(()=>{confetti({particleCount:40,angle:60,spread:55,origin:{x:0}});confetti({particleCount:40,angle:120,spread:55,origin:{x:1}})},800)}
  cart={};updateAll();
}
</script>
</body>
</html>
