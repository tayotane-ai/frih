        <div class="ps-note" id="psNote"></div>
      </div>
      <div class="mstep" id="mstep2">
        <div class="loading-wrap" style="text-align:center;padding:50px 0">
          <div class="spinner"></div>
          <p style="font-weight:600;font-size:15px">Connecting to Paystack...</p>
          <p style="color:var(--soft);font-size:13px;margin-top:6px">You'll be redirected to complete payment</p>
        </div>
      </div>
    </div>
  </div>
</div>
