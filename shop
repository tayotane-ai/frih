<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Frih — Made to Move with you</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,200;12..96,300;12..96,400;12..96,500;12..96,600;12..96,700;12..96,800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/canvas-confetti/1.9.3/confetti.browser.min.js" defer></script>
<script src="https://js.paystack.co/v1/inline.js" async></script>
<style>
  :root{--bg:#F4F3F1;--ink:#131210;--soft:#8a857d;--card:#ECEAE5;--hair:#dedad2;--green:#1a7a2e;--red:#e03e2d;--pad:clamp(16px,3vw,40px);--ease:cubic-bezier(.22,.61,.36,1)}
  *{box-sizing:border-box;margin:0;padding:0}html{scroll-behavior:smooth}
  body{background:var(--bg);color:var(--ink);font-family:"Inter",system-ui,sans-serif;-webkit-font-smoothing:antialiased;overflow-x:hidden}
  a{color:inherit;text-decoration:none}button{font-family:inherit;cursor:pointer;border:none}
  svg{vertical-align:middle;flex-shrink:0}

  nav{display:flex;align-items:center;justify-content:space-between;padding:20px var(--pad);position:sticky;top:0;z-index:50;background:var(--bg)}
  .logo svg{height:28px;width:auto}
  .ig-link{color:var(--ink);opacity:.7;transition:opacity .3s;display:flex}.ig-link:hover{opacity:1}

  .hero{padding:clamp(30px,8vh,100px) var(--pad) clamp(24px,5vh,50px);text-align:center}
  .hero h1{font-family:"Bricolage Grotesque","Inter",sans-serif;font-weight:500;font-size:clamp(44px,10vw,160px);line-height:.88;letter-spacing:-.04em}
  .hero h1 em{font-style:italic;font-weight:300}
  .hero p{margin-top:clamp(14px,2.4vh,28px);color:var(--soft);font-size:15px;max-width:400px;margin-left:auto;margin-right:auto;line-height:1.5}

  .tabs-wrap{padding:0 var(--pad);margin-bottom:2px}
  .tabs{display:flex;background:#E4E1DB;border-radius:10px;padding:4px;gap:4px}
  .tab{flex:1;padding:12px 16px;border-radius:8px;font-size:13.5px;font-weight:500;color:var(--soft);background:transparent;transition:all .3s var(--ease);text-align:center}
  .tab[aria-selected="true"]{background:#fff;color:var(--ink);box-shadow:0 1px 4px rgba(0,0,0,.08)}
  .tab .n{font-size:11px;opacity:.5;margin-left:4px}

  .grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--hair);border-top:1px solid var(--hair)}
  .card{position:relative;background:var(--card);aspect-ratio:1/1;overflow:hidden;opacity:0;transform:translateY(22px);transition:opacity .6s var(--ease),transform .6s var(--ease)}
  .card.in{opacity:1;transform:none}.card.hide{display:none}

  /* PRODUCT PHOTO — bigger, white bg */
  .photo{position:absolute;inset:4px 4px 56px;display:flex;align-items:center;justify-content:center;background:#fff;border-radius:10px}
  .photo img{max-height:94%;max-width:92%;object-fit:contain;transition:transform .6s var(--ease)}
  .card:hover .photo img{transform:scale(1.03)}

  .tag-idx{position:absolute;top:22px;left:22px;font-size:10.5px;letter-spacing:.12em;color:var(--soft);font-weight:500;z-index:2}

  /* LABEL BAR */
  .label{position:absolute;left:0;right:0;bottom:0;height:56px;border-top:1px solid var(--hair)}
  .lab-default{position:absolute;inset:0;display:flex;align-items:center;justify-content:space-between;padding:0 18px;font-size:11.5px;letter-spacing:.06em;text-transform:uppercase;color:#3a3833;font-weight:500;z-index:1}
  .lab-default .pricing{display:flex;align-items:center;gap:8px;text-transform:none;letter-spacing:0}
  .lab-default .now{font-weight:700;color:var(--ink);font-size:13px}
  .lab-default .was{font-weight:400;color:var(--soft);font-size:11.5px;text-decoration:line-through}

  .lab-atc{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;gap:10px;background:var(--ink);color:#fff;font-weight:600;font-size:13.5px;letter-spacing:.03em;text-transform:uppercase;opacity:0;pointer-events:none;z-index:2;transition:opacity .3s var(--ease);cursor:pointer}
  .card:hover .lab-atc.can-add,.lab-atc.can-add.always{opacity:1;pointer-events:auto}

  .lab-qty{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;gap:0;background:var(--ink);opacity:0;pointer-events:none;z-index:3;transition:opacity .3s var(--ease)}
  .card:hover .lab-qty.has-items,.lab-qty.has-items.always{opacity:1;pointer-events:auto}
  .lab-qty .qbtn{height:100%;width:64px;display:flex;align-items:center;justify-content:center;color:#fff;background:none;transition:background .2s;cursor:pointer}
  .lab-qty .qbtn:hover{background:rgba(255,255,255,.14)}
  .lab-qty .qbtn.del{color:#ff8a80}
  .lab-qty .qbtn.del:hover{background:rgba(255,100,80,.15)}
  .lab-qty .qcount{flex:1;text-align:center;color:#fff;font-weight:700;font-size:16px;letter-spacing:.05em}

  /* CART BAR */
  .cart-bar{position:fixed;bottom:0;left:0;right:0;z-index:100;background:#fff;border-top:1px solid var(--hair);padding:14px var(--pad);display:flex;align-items:center;justify-content:space-between;gap:14px;transform:translateY(100%);transition:transform .45s var(--ease);box-shadow:0 -8px 40px rgba(0,0,0,.08)}
  .cart-bar.show{transform:none}
  .cart-left{display:flex;align-items:center;gap:12px}
  .cart-icon{position:relative;width:42px;height:42px;border-radius:50%;background:var(--ink);display:flex;align-items:center;justify-content:center;color:#fff}
  .cart-badge{position:absolute;top:-5px;right:-5px;min-width:20px;height:20px;border-radius:10px;background:var(--red);color:#fff;font-size:11px;font-weight:700;display:flex;align-items:center;justify-content:center;padding:0 5px}
  .cart-text{font-size:13px;color:var(--soft)}.cart-text b{color:var(--ink);font-weight:600}
  .cart-discount{font-size:11.5px;color:var(--green);font-weight:600;background:#e8f5e9;padding:5px 12px;border-radius:20px;white-space:nowrap;display:flex;align-items:center;gap:6px}
  .preorder-btn{background:var(--ink);color:#fff;font-weight:600;font-size:14px;padding:14px 28px;border-radius:30px;font-family:"Bricolage Grotesque","Inter",sans-serif;transition:transform .3s var(--ease);white-space:nowrap;display:flex;align-items:center;gap:8px}
  .preorder-btn:hover{transform:translateY(-1px)}

  .overlay{position:fixed;inset:0;z-index:200;background:rgba(0,0,0,.4);backdrop-filter:blur(4px);display:flex;align-items:center;justify-content:center;padding:20px;opacity:0;pointer-events:none;transition:opacity .35s var(--ease)}
  .overlay.open{opacity:1;pointer-events:auto}
  .modal{background:#fff;border-radius:18px;width:100%;max-width:520px;max-height:90vh;overflow-y:auto;transform:translateY(20px);transition:transform .4s var(--ease);box-shadow:0 24px 80px rgba(0,0,0,.16)}
  .overlay.open .modal{transform:none}
  .modal-head{padding:24px 24px 0;display:flex;align-items:center;justify-content:space-between}
  .modal-head h2{font-family:"Bricolage Grotesque","Inter",sans-serif;font-weight:600;font-size:22px;letter-spacing:-.02em}
  .close-btn{width:36px;height:36px;border-radius:50%;background:#f4f3f1;display:flex;align-items:center;justify-content:center;color:var(--ink);transition:background .2s;cursor:pointer}
  .close-btn:hover{background:#e4e2de}
  .modal-body{padding:20px 24px 24px}
  .mstep{display:none}.mstep.active{display:block}

  .cart-item{display:flex;align-items:center;gap:12px;padding:12px 0;border-bottom:1px solid #f0eeea}
  .cart-item img{width:50px;height:50px;object-fit:contain;border-radius:8px;background:var(--card)}
  .ci-info{flex:1;min-width:0}.ci-name{font-weight:600;font-size:13.5px}.ci-type{font-size:12px;color:var(--soft)}
  .ci-right{display:flex;align-items:center;gap:10px;flex-shrink:0}
  .ci-qty{display:flex;align-items:center;border:1px solid var(--hair);border-radius:8px;overflow:hidden}
  .ci-qty button{width:34px;height:34px;background:#fafaf8;display:flex;align-items:center;justify-content:center;color:var(--ink);transition:background .2s;cursor:pointer;border:none}
  .ci-qty button:hover{background:#eee}
  .ci-qty button.del{color:var(--red)}
  .ci-qty .ciq{width:32px;text-align:center;font-weight:700;font-size:13px;border-left:1px solid var(--hair);border-right:1px solid var(--hair)}
  .ci-price{font-weight:700;font-size:14px;white-space:nowrap;min-width:72px;text-align:right}

  .cart-summary{margin-top:16px;padding:16px;background:#f9f8f6;border-radius:12px}
  .cs-row{display:flex;justify-content:space-between;font-size:13px;color:#4a473f;padding:4px 0}
  .cs-row.total{font-weight:700;font-size:15px;color:var(--ink);border-top:1px solid var(--hair);margin-top:8px;padding-top:10px}
  .cs-row .saved{color:var(--green);font-weight:600}

  .field{margin-bottom:14px}
  .field label{display:block;font-size:12px;font-weight:600;color:var(--soft);text-transform:uppercase;letter-spacing:.08em;margin-bottom:6px}
  .field input{width:100%;padding:13px 14px;border:1px solid var(--hair);border-radius:10px;font-size:14px;font-family:inherit;background:#fafaf8;transition:border-color .25s}
  .field input:focus{outline:none;border-color:var(--ink)}
  .field-row{display:grid;grid-template-columns:1fr 1fr;gap:12px}
  .proceed-btn{width:100%;margin-top:18px;padding:16px;border-radius:30px;background:var(--ink);color:#fff;font-family:"Bricolage Grotesque","Inter",sans-serif;font-weight:600;font-size:15px;transition:transform .3s var(--ease);display:flex;align-items:center;justify-content:center;gap:10px;cursor:pointer}
  .proceed-btn:hover{transform:translateY(-1px)}
  .proceed-btn:disabled{opacity:.5;cursor:not-allowed;transform:none}

  .spinner{width:52px;height:52px;border:4px solid var(--hair);border-top-color:var(--ink);border-radius:50%;animation:spin .8s linear infinite;margin:0 auto 20px}
  @keyframes spin{to{transform:rotate(360deg)}}

  .ps-note{margin-top:14px;padding:14px;background:#f0f7ff;border-radius:10px;font-size:12.5px;color:#3a3833;line-height:1.45;display:flex;align-items:flex-start;gap:10px}
  .ps-note svg{flex-shrink:0;margin-top:1px}

  .order-page{display:none;min-height:100vh;background:#fff}
  .order-page.show{display:block}
  .order-page .op-nav{display:flex;align-items:center;justify-content:center;padding:24px var(--pad);border-bottom:1px solid var(--hair)}
  .order-page .op-nav svg{height:28px}
  .op-body{max-width:560px;margin:0 auto;padding:clamp(30px,6vh,60px) 20px 60px}
  .op-check{width:72px;height:72px;border-radius:50%;background:#e8f5e9;display:flex;align-items:center;justify-content:center;margin:0 auto 20px;color:var(--green)}
  .op-body h2{text-align:center;font-family:"Bricolage Grotesque","Inter",sans-serif;font-weight:600;font-size:clamp(24px,5vw,32px);letter-spacing:-.02em;margin-bottom:6px}
  .op-body .sub{text-align:center;color:var(--soft);font-size:14px;margin-bottom:8px}
  .order-id{text-align:center;font-size:12px;color:var(--soft);letter-spacing:.12em;text-transform:uppercase;margin-bottom:28px}
  .timeline{position:relative;padding-left:32px;margin:24px 0}
  .timeline::before{content:"";position:absolute;left:9px;top:4px;bottom:4px;width:2px;background:var(--hair)}
  .tl-step{position:relative;padding-bottom:22px}.tl-step:last-child{padding-bottom:0}
  .tl-dot{position:absolute;left:-28px;top:2px;width:14px;height:14px;border-radius:50%;border:2px solid var(--hair);background:#fff}
  .tl-step.done .tl-dot{background:var(--green);border-color:var(--green)}
  .tl-step.current .tl-dot{background:var(--ink);border-color:var(--ink);box-shadow:0 0 0 4px rgba(19,18,16,.12)}
  .tl-title{font-weight:600;font-size:14px;display:flex;align-items:center;gap:8px}
  .tl-desc{font-size:12.5px;color:var(--soft);margin-top:2px}

  footer{padding:clamp(48px,9vh,110px) var(--pad) 28px;padding-bottom:100px}
  footer .lockup{font-family:"Bricolage Grotesque","Inter",sans-serif;font-weight:600;font-size:clamp(36px,10vw,160px);line-height:.84;letter-spacing:-.045em}
  footer .lockup em{font-style:italic;font-weight:300}
  footer .frow{display:flex;justify-content:space-between;gap:16px;margin-top:30px;padding-top:20px;border-top:1px solid var(--hair);color:var(--soft);font-size:12px;flex-wrap:wrap}
  .main-wrap.hidden{display:none}

  @media(max-width:900px){.grid{grid-template-columns:repeat(2,1fr)}.tabs{flex-wrap:wrap}.tab{flex:1 1 48%}}
  @media(max-width:560px){.grid{grid-template-columns:1fr}.card{aspect-ratio:4/5}.field-row{grid-template-columns:1fr}}
  @media(prefers-reduced-motion:reduce){*{transition:none!important}.card{opacity:1;transform:none}}
</style>
</head>
